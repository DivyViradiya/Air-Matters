# Air Matters Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# App name and URL
VITE_APP_NAME=Air Matters
VITE_APP_URL=http://localhost:5000

# ============================================================
# API CONFIGURATION
# ============================================================

# Open-Meteo Air Quality API (Free - No API key required)
# Endpoint: https://air-quality-api.open-meteo.com/v1/air-quality
# Used in: AirQualitySection.tsx

# OpenStreetMap Nominatim (Free - No API key required)
# Endpoint: https://nominatim.openstreetmap.org
# Used for reverse geolocation

# ============================================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================================

# Google Analytics
# VITE_GA_ID=

# Sentry Error Tracking
# VITE_SENTRY_DSN=

# Plausible Analytics
# VITE_PLAUSIBLE_DOMAIN=

# ============================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================

# Enable/disable features in production
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_TESTIMONIALS=false
# VITE_ENABLE_BLOG=false

# ============================================================
# NODE ENVIRONMENT
# ============================================================

# Do NOT change in production
NODE_ENV=development

# ============================================================
# NOTES
# ============================================================

# 1. For local development, create .env.local with these values
# 2. For production deployment, set these variables in your platform settings.
#
# 3. VITE_ prefix is required for frontend environment variables
#    They will be available as import.meta.env.VITE_*
#    Example: import.meta.env.VITE_APP_NAME

# 4. Keep .env.local out of version control (already in .gitignore)
# 5. Never commit real API keys or secrets
# 6. Always use this template to document required variables
